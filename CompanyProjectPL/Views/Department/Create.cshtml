@model CreateDepartmentDto
<div class="row justify-content-center align-content-center mt-3">
    <h1 class="col-8 my-4">Create Department</h1>

    <form class="col-8" method="post" asp-action="Create" asp-controller="Department">
        @*method="post" => must have create action od type post *@

        <div asp-validation-summary="ModelOnly"></div>

        <partial name="PartialViews/CreateEditView" />


        <div class="mt-4 m-auto">
            <input class="btn btn-primary" type="submit" value="Create" />
            <a class="btn btn-outline-dark" asp-action="Index">Back to list</a>
        </div>
    </form>
</div>